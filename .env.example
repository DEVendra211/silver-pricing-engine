# Copy this file to .env and fill in your values. Never commit .env.

# Your store's *.myshopify.com domain, e.g. maa-silver.myshopify.com
SHOPIFY_STORE_DOMAIN=

# Admin API access token from a custom app (Settings > Apps and sales channels
# > Develop apps > Create an app). Required scopes:
#   read_products, write_products, read_metaobjects, write_metaobjects
SHOPIFY_ADMIN_ACCESS_TOKEN=

# Admin API version to call
SHOPIFY_API_VERSION=2025-01

# Port for the local admin panel
PORT=3456

# Login for the admin panel itself (HTTP Basic Auth). REQUIRED once you host
# this somewhere public (Render/Vercel) — without it, anyone with the URL
# could change your rate or trigger a recalculation. Not needed for
# localhost-only use, but set it anyway so deploying later is a no-op.
ADMIN_USERNAME=admin
ADMIN_PASSWORD=
